---
// src/pages/admin/[...index].astro
import SanityStudio from '@/components/SanityStudio';

export function getStaticPaths() {
  return [{ params: { index: undefined } }];
}
---

<SanityStudio client:only='react' />

<style is:global>
  /* Reset total untuk memastikan tidak ada gangguan layout */
  :root,
  html,
  body {
    height: 100vh !important;
    width: 100vw !important;
    margin: 0 !important;
    padding: 0 !important;
    overflow: hidden !important; /* Mencegah double scroll */
  }

  /* Memastikan Sanity rendering area mengambil sisa ruang */
  [data-ui='Root'] {
    height: 100vh !important;
  }
</style>
