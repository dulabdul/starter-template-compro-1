---
// src/pages/index.astro
import BaseLayout from '@/layouts/BaseLayout.astro';
import Navbar from '@/components/layout/Navbar';
import Services from '@/components/sections/Services.astro';
import Contact from '@/components/sections/Contact.astro';
import { sanityClient } from '@/lib/sanity';
import Hero from '@/components/sections/Hero.astro';
import About from '@/components/sections/About.astro';
import Cultures from '@/components/sections/Cultures.astro';
import Client from '@/components/sections/Client.astro';
import Footer from '@/components/layout/Footer.astro';
import FloatingWhatsApp from '@/components/ui/FloatingWhatsApp';

// Fetch nama perusahaan untuk Navbar
const companyInfo = await sanityClient.fetch(
  `*[_type == "companyInfo"][0]{ 
    companyName, 
    whatsapp, 
    whatsappMessage 
  }`,
);
const brandName = companyInfo?.companyName || 'CorpBrand.';
const waNumber = companyInfo?.whatsapp || '1234567890';
const waMessage =
  companyInfo?.whatsappMessage || 'Halo! Saya tertarik dengan layanan Anda.';
---

<BaseLayout title='Home'>
  <Navbar
    companyName={brandName}
    client:load
  />

  <main class='pt-16'>
    <Hero />
    <About />
    <Cultures />
    <Services />
    <Client />
    <Contact />
  </main>
  <Footer />
  <FloatingWhatsApp
    phoneNumber={waNumber}
    message={waMessage}
    client:load
  />
</BaseLayout>
