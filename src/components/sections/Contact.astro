---
// src/components/sections/Contact.astro
import { sanityClient } from '@/lib/sanity';

// 1. Buat tipe data sesuai schema Sanity
interface CompanyInfo {
  email: string;
  address: string;
}

// 2. Fetch data (karena singleton, kita ambil index [0])
const companyInfo = await sanityClient.fetch<CompanyInfo>(
  `*[_type == "companyInfo"][0]`,
);

// 3. Pasang fallback jika data di Sanity masih kosong
const email = companyInfo?.email || 'contact@corpbrand.com';
const address =
  companyInfo?.address || '123 Business Avenue, Suite 100, Metropolis';
---

<section
  id='contact'
  class='bg-slate-100 py-24'>
  <div class='container mx-auto px-4 text-center md:px-8'>
    <h2 class='text-3xl font-bold text-slate-900'>Get in Touch</h2>
    <p class='mt-6 text-slate-600'>We are here to help your business grow.</p>

    <div class='mt-8 flex flex-col items-center gap-4'>
      <p class='text-lg font-medium'>{address}</p>
      <a
        href={`mailto:${email}`}
        class='text-blue-600 hover:underline text-lg font-semibold'>
        {email}
      </a>
    </div>
  </div>
</section>
