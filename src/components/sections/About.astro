---
// src/components/sections/About.astro
import { sanityClient, urlFor } from '@/lib/sanity';

interface Stat {
  value: string;
  label: string;
}

interface AboutData {
  title?: string;
  badge?: string;
  description?: string;
  imageLeft?: any;
  imageRight?: any;
  stats?: Stat[];
}

// Ambil data dari CMS
const data = await sanityClient.fetch<AboutData>(`*[_type == "aboutUs"][0]`);

// Fallbacks (Data Default jika Sanity masih kosong)
const title = data?.title || 'About-<br/>Company.';
const badge = data?.badge || 'About the Company';
const description =
  data?.description ||
  'Innovative Solutions is a cutting-edge technology company that provides innovative solutions for businesses of all sizes. Founded in 2010, we are dedicated to helping our clients achieve their goals through our customized and effective technology solutions. With over a decade of experience, we have built a reputation for delivering high-quality services to our clients.';

const imgLeftUrl = data?.imageLeft
  ? urlFor(data.imageLeft).url()
  : 'https://images.unsplash.com/photo-1513694203232-719a280e022f?q=80&w=800&auto=format&fit=crop'; // Gambar gedung berdaun dummy

const imgRightUrl = data?.imageRight
  ? urlFor(data.imageRight).url()
  : 'https://images.unsplash.com/photo-1506526685822-1b1d4c229984?q=80&w=500&auto=format&fit=crop'; // Gambar lorong putih dummy

const stats = data?.stats || [
  { value: '2022', label: 'Founded' },
  { value: '96', label: 'Clients' },
  { value: '140', label: 'Projects done' },
  { value: '61', label: '5-Stars Review' },
];
---

<section
  id='about'
  class='py-20 md:py-32 bg-[#FAFAFA]'>
  <div class='container mx-auto px-4 md:px-8'>
    <div class='grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-8'>
      <div class='lg:col-span-5 flex flex-col gap-10'>
        <h2
          class='text-5xl md:text-7xl font-bold text-slate-900 leading-[1.1] tracking-tight'
          set:html={title}
        />

        <div
          class='w-full aspect-square md:aspect-[4/3] lg:aspect-square rounded-[2rem] overflow-hidden shadow-xl'>
          <img
            src={imgLeftUrl}
            alt='About Left Image'
            class='w-full h-full object-cover'
          />
        </div>
      </div>

      <div class='lg:col-span-7 flex flex-col pt-4 lg:pt-0 relative'>
        <div
          class='self-end lg:absolute lg:top-0 lg:right-0 w-48 h-64 md:w-64 md:h-80 rounded-t-[100px] rounded-b-[2rem] overflow-hidden shadow-lg mb-8 lg:mb-0 z-10'>
          <img
            src={imgRightUrl}
            alt='About Right Image'
            class='w-full h-full object-cover'
          />
        </div>

        <div class='lg:mt-auto lg:pt-56 lg:pr-32'>
          <div
            class='inline-block bg-[#333333] text-white px-6 py-2.5 rounded-full text-sm font-semibold mb-6'>
            {badge}
          </div>

          <p class='text-slate-600 leading-relaxed text-lg mb-12 text-justify'>
            {description}
          </p>

          <div class='grid grid-cols-2 md:grid-cols-4 gap-6 md:gap-8'>
            {
              stats.map((stat) => (
                <div class='flex flex-col gap-1'>
                  <span class='text-3xl md:text-4xl font-extrabold text-slate-900'>
                    {stat.value}
                  </span>
                  <span class='text-sm font-medium text-slate-500'>
                    {stat.label}
                  </span>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
