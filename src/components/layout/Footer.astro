---
// src/components/layout/Footer.astro
import { sanityClient } from '@/lib/sanity';

// 1. Definisikan Interface
interface SiteSettings {
  description?: string;
}

interface CompanyInfo {
  companyName?: string; // Tambahkan ini
  email?: string;
  whatsapp?: string;
}

// 2. Fetch Data dari DUA skema berbeda secara paralel agar lebih cepat
const [settings, company] = await Promise.all([
  sanityClient.fetch<SiteSettings>(`*[_type == "siteSettings"][0]`),
  sanityClient.fetch<CompanyInfo>(`*[_type == "companyInfo"][0]`),
]);

// 3. Setup Fallback Variables
// Ambil brandName dari companyInfo sekarang
const brandName = company?.companyName || 'CorpBrand.';

const description =
  settings?.description ||
  'Kami menghadirkan solusi digital dan layanan profesional kelas atas untuk mengakselerasi pertumbuhan bisnis Anda di era modern.';

const email = company?.email || 'info@innovativesolutions.com';
const whatsapp = company?.whatsapp || '937-767-6889';

// Membersihkan nomor WA dari spasi/strip agar link wa.me berfungsi dengan baik
const cleanWhatsappStr = whatsapp.replace(/[^0-9]/g, '');

// Dapatkan tahun saat ini secara dinamis
const currentYear = new Date().getFullYear();
---

<footer class='bg-[#1A1A1A] text-slate-300 py-16 border-t border-slate-800'>
  <div class='container mx-auto px-4 md:px-8 max-w-6xl'>
    <div class='grid grid-cols-1 md:grid-cols-12 gap-12 md:gap-8 mb-16'>
      <div class='md:col-span-5 flex flex-col items-start'>
        <a
          href='/'
          class='text-3xl font-bold text-white tracking-tight mb-6'>
          {brandName}
        </a>
        <p class='text-slate-400 leading-relaxed text-lg max-w-sm text-justify'>
          {description}
        </p>
      </div>

      <div class='md:col-span-3 lg:col-start-7 flex flex-col'>
        <h3 class='text-white text-lg font-semibold mb-6'>Quick Links</h3>
        <ul class='flex flex-col gap-4'>
          <li>
            <a
              href='#about'
              class='hover:text-white transition-colors'
              >About Us</a
            >
          </li>
          <li>
            <a
              href='#services'
              class='hover:text-white transition-colors'
              >Services</a
            >
          </li>
          <li>
            <a
              href='#portfolio'
              class='hover:text-white transition-colors'
              >Portfolio</a
            >
          </li>
          <li>
            <a
              href='#contact'
              class='hover:text-white transition-colors'
              >Contact</a
            >
          </li>
        </ul>
      </div>

      <div class='md:col-span-4 lg:col-span-3 flex flex-col'>
        <h3 class='text-white text-lg font-semibold mb-6'>Reach Out</h3>
        <ul class='flex flex-col gap-5'>
          <li>
            <a
              href={`mailto:${email}`}
              class='flex items-center gap-3 hover:text-white transition-colors group'>
              <span
                class='w-10 h-10 rounded-full bg-[#333333] flex items-center justify-center group-hover:bg-slate-700 transition-colors'>
                <svg
                  xmlns='http://www.w3.org/2000/svg'
                  width='18'
                  height='18'
                  viewBox='0 0 24 24'
                  fill='none'
                  stroke='currentColor'
                  stroke-width='2'
                  stroke-linecap='round'
                  stroke-linejoin='round'
                  class='text-white'
                  ><rect
                    width='20'
                    height='16'
                    x='2'
                    y='4'
                    rx='2'
                  ></rect><path d='m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7'
                  ></path></svg
                >
              </span>
              <span class='truncate'>{email}</span>
            </a>
          </li>
          <li>
            <a
              href={`https://wa.me/${cleanWhatsappStr}`}
              target='_blank'
              rel='noopener noreferrer'
              class='flex items-center gap-3 hover:text-white transition-colors group'>
              <span
                class='w-10 h-10 rounded-full bg-[#333333] flex items-center justify-center group-hover:bg-slate-700 transition-colors'>
                <svg
                  xmlns='http://www.w3.org/2000/svg'
                  width='18'
                  height='18'
                  viewBox='0 0 24 24'
                  fill='none'
                  stroke='currentColor'
                  stroke-width='2'
                  stroke-linecap='round'
                  stroke-linejoin='round'
                  class='text-white'
                  ><path
                    d='M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z'
                  ></path></svg
                >
              </span>
              <span>{whatsapp}</span>
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div
      class='pt-8 border-t border-slate-800 text-sm flex flex-col md:flex-row justify-between items-center gap-4 text-slate-500'>
      <p>&copy; {currentYear} {brandName}. All rights reserved.</p>
      <p>Designed with Astro & Sanity</p>
    </div>
  </div>
</footer>
